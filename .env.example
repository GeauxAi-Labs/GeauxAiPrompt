# Server port - The port on which the application will run (default: 3000)
PORT=3000

# App package name - Your application's unique identifier. Must match the MentraOS Developer Console.
PACKAGE_NAME=com.geauxailabs.geauxaiprompt

# API key - Your MentraOS developer API key from the MentraOS Developer Console
MENTRA_API_KEY=your_mentra_api_key_here

OWNER_EMAIL=your@email.com

─────────────────────────────────────────────────────────────
# AI connections

# Ollama

AI_PROVIDER=ollama

OLLAMA_HOST=http://localhost:11434
# OLLAMA_HOST=http://172.17.176.1:11434

# AI model to use (uncomment one, or set via web UI params)
# AI_MODEL=llama3.2:3b
# AI_MODEL=dolphin-llama3:8b
# AI_MODEL=llama3.2:latest
# AI_MODEL=phi4-mini:latest
# AI_MODEL=qwen3.5:397b-cloud
# AI_MODEL=deepseek-v3.1:671b-cloud
# AI_MODEL=deepseek-v3.2:cloud
# AI_MODEL=gemini-3-flash-preview:cloud

#Cloudflare

CF_ACCOUNT_ID=3c6370dcd3154cf46fc28d763224c023
CF_API_TOKEN=TsEP4EIFoRg2JrbTXRLn1XhLOlfAUYkHmnDiuPBJ

# Not used 
# OpenAI API key (required when AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Anthropic API key (required when AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# ── Display Timing ─────────────────────────────────────────────────────────────
# Milliseconds to pause between AI response pages on glasses (4s = comfortable reading pace)
PAGE_DELAY_MS=4000

# Milliseconds after the final page before the glasses display is auto-cleared
AUTO_CLEAR_DELAY_MS=15000

# Milliseconds before a status/confirmation message (mic toggle, history cleared) is auto-cleared
STATUS_CLEAR_DELAY_MS=5000

# ── Wake Word ──────────────────────────────────────────────────────────────────
# Voice input is silently ignored unless the transcription starts with this phrase (case-insensitive).
# The wake word is stripped before sending to the AI. Typed prompts bypass this entirely.
WAKE_WORD=Go AI

# ── Web Search ─────────────────────────────────────────────────────────────────
# Enable live web search via Tavily (true by default)
WEB_SEARCH_ENABLED=true

# Tavily AI Search API key — get a free key at tavily.com (1000 queries/month free)
TAVILY_API_KEY=your_tavily_api_key_here

# ── TTS ────────────────────────────────────────────────────────────────────────
# ElevenLabs cloud TTS (optional — Kokoro is the local alternative)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# ELEVENLABS_VOICE_ID=ZzBpNW0j7Iq2XRx6Xo49

# Kokoro local TTS server
KOKORO_HOST=http://localhost:8880
KOKORO_VOICE=bf_v0isabella

──────────────────────────────────────────────────────────────────────
