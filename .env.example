# Server port - The port on which the application will run (default: 3000)
PORT=3000

# App package name - Your application's unique identifier.  Make sure it exactly matches the package name in the MentraOS Developer Console
PACKAGE_NAME=

# API key - Your MentraOS developer API key from the MentraOS Developer Console (never commit the key to source control)
MENTRA_API_KEY=

AI_PROVIDER=ollama

OLLAMA_HOST=http://localhost:11434
# OLLAMA_HOST=http://172.17.176.1:11434

# AI_MODEL=llama3.2:3b
# AI_MODEL=dolphin-llama3:8b
# AI_MODEL=llama3.2:latest
# AI_MODEL=phi4-mini:latest
# AI_MODEL=qwen3.5:397b-cloud
# AI_MODEL=deepseek-v3.1:671b-cloud
# AI_MODEL=deepseek-v3.2:cloud
# AI_MODEL=gemini-3-flash-preview:cloud


OWNER_EMAIL=
#OPENAI_API_KEY=
# Milliseconds to pause between AI response pages on glasses (default: 5000)
PAGE_DELAY_MS=9000

# Milliseconds after the final page before the glasses display is auto-cleared (default: 15000)
AUTO_CLEAR_DELAY_MS=15000

# Milliseconds before a status/confirmation message (mic toggle, history cleared) is auto-cleared (default: 5000)
STATUS_CLEAR_DELAY_MS=5000

# Wake word that must prefix all voice prompts before they are processed (default: "hey go").
# Voice input is silently ignored unless the transcription starts with this phrase (case-insensitive).
# The wake word is stripped from the text before it is sent to the AI.
# Typed prompts via the web UI bypass wake-word filtering entirely.
WAKE_WORD=Go AI

# Enable web search via DuckDuckGo (true by default, set to false to disable)
WEB_SEARCH_ENABLED=true

# Tavily AI Search API key — get a free key at tavily.com (1000 queries/month free)
TAVILY_API_KEY=


# Voice from phone 
ELEVENLABS_API_KEY=

KOKORO_HOST=http://localhost:8880
KOKORO_VOICE=bf_v0isabella
